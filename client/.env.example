# =============================================================================
# Hypergoat Client Configuration
# =============================================================================

# Backend API URL (the Go server)
# For local development: http://localhost:8080
# For production: https://your-railway-app.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8080

# Same as above, used for server-side API calls
HYPERGOAT_URL=http://127.0.0.1:8080

# =============================================================================
# OAuth Configuration
# =============================================================================

# Public URL of this client (required for production OAuth)
# This is the Vercel URL where the client is deployed
# Leave empty for local development (uses http://127.0.0.1:3000)
PUBLIC_URL=

# Secret for encrypting session cookies (REQUIRED, must be at least 32 characters)
# Generate with: openssl rand -base64 32
# WARNING: The app will refuse to start without a valid secret.
COOKIE_SECRET=

# Shared admin API key (must match the Go backend's ADMIN_API_KEY).
# When set, the client proxy sends this as a Bearer token alongside
# X-User-DID so the backend trusts the forwarded session identity.
# Generate with: openssl rand -base64 32
ADMIN_API_KEY=

# Admin bootstrap note
# --------------------
# The settings page client-side gate hides destructive controls
# (Danger Zone, actor purge) from anyone whose session DID is not
# in the server's `settings.adminDids` list. The list is seeded
# from the backend's ADMIN_DIDS env var on first boot. If you
# deploy without ADMIN_DIDS set, the first OAuth login still
# works — but the settings page will render in read-only mode
# for everyone. Recover by setting ADMIN_DIDS in the backend env
# and restarting; the gate is UX only and the server is the
# security boundary.

# Private JWK for confidential OAuth client (optional)
# For production, you can generate a key pair with:
#   npm run gen-keys
# Then paste the private key JSON here (minified, single line)
# Leave empty to use public client mode (simpler, works for most cases)
ATPROTO_JWK_PRIVATE=
