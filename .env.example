# Hypergoat Configuration
# Copy this file to .env and modify as needed

# =============================================================================
# Server Configuration
# =============================================================================

# Host to bind to (use 0.0.0.0 for Docker, 127.0.0.1 for local development)
HOST=127.0.0.1

# Port to listen on
PORT=8080

# =============================================================================
# Database Configuration
# =============================================================================

# Database connection URL (Postgres required)
# Example: postgres://user:pass@localhost:5432/hypergoat?sslmode=disable
DATABASE_URL=postgres://hypergoat:hypergoat@localhost:5432/hypergoat?sslmode=disable

# =============================================================================
# Security Configuration
# =============================================================================

# Secret key for session encryption (must be at least 64 characters).
# Generate one with: openssl rand -base64 64
# `make setup` will fill this in automatically.
# IMPORTANT: This MUST be persistent across restarts or sessions
# will be invalidated. config.Validate() rejects the docker-compose
# development placeholder string at startup.
SECRET_KEY_BASE=CHANGE_ME_TO_A_RANDOM_64_CHARACTER_STRING_USE_OPENSSL_RAND

# Allowed origins for CORS and WebSocket connections (comma-separated)
# Empty or unset = allow all origins. Set explicit origins in production.
# Supports wildcard patterns for preview deployments.
# Examples: https://myapp.com,https://admin.myapp.com
# ALLOWED_ORIGINS=https://certs.social,https://certs-social-*.vercel.app

# Admin DIDs (comma-separated) - users with admin access to the dashboard
# Replace with your own DID(s) before deploying.
ADMIN_DIDS=

# Shared secret for admin API authentication (RECOMMENDED for production).
# When set, the X-User-DID header is trusted only if the request also
# carries a matching Authorization: Bearer <key> header. Without this,
# the admin endpoint is accessible only via OAuth (no CLI/proxy support).
# Generate with: openssl rand -base64 32
ADMIN_API_KEY=

# Domain DID for server identity (defaults to did:web:{HOST})
# DOMAIN_DID=

# =============================================================================
# OAuth Configuration
# =============================================================================

# External base URL for OAuth redirects and client metadata
# The redirect URI will be: ${EXTERNAL_BASE_URL}/oauth/callback
# Defaults to http://{HOST}:{PORT} if not set
# For loopback mode, use 127.0.0.1 (not localhost) per RFC 8252
# EXTERNAL_BASE_URL=http://127.0.0.1:8080

# OAuth signing key in multibase format (for JWT signing)
# Generate with the key generation utility
# OAUTH_SIGNING_KEY=

# OAuth loopback mode - enables local development without ngrok/tunnels
# When true, uses loopback client IDs: http://localhost/?redirect_uri=...&scope=...
# Set to "true" for local development, leave unset for production
# OAUTH_LOOPBACK_MODE=true

# Domain DID (issue #57). Required to enable the service-auth
# notifications endpoint `/notifications/graphql`. Every incoming
# service-auth JWT is validated against this DID as the `aud` claim, so
# an incorrect value silently 401s every caller. Must start with
# `did:plc:` or `did:web:`; malformed values are fatal at startup.
# If unset, the endpoint is not mounted and callers must keep using
# `/admin/graphql` with the admin-key path (transition mode).
# DOMAIN_DID=did:web:indexer.example.com

# OAuth DPoP key-binding sunset cutoff (Unix timestamp, REQUIRED - issue #24).
# Refresh tokens issued before this timestamp are accepted without a DPoP JKT
# binding (legacy path); tokens issued at or after must be JKT-bound. Set to
# the deploy time of the DPoP-binding feature so existing sessions keep
# refreshing until they expire. The server refuses to start if this is unset
# or non-positive (fail-closed).
# OAUTH_LEGACY_DPOP_JKT_CUTOFF=1744416000

# =============================================================================
# Lexicon Configuration
# =============================================================================

# Directory to load lexicon JSON files from (default: testdata/lexicons)
# LEXICON_DIR=

# =============================================================================
# Jetstream Configuration
# =============================================================================

# Jetstream WebSocket URL (default: wss://jetstream2.us-west.bsky.network/subscribe)
# JETSTREAM_URL=

# Collections to subscribe to via Jetstream (comma-separated NSIDs)
# If not set, uses collections from registered lexicons
# JETSTREAM_COLLECTIONS=

# Disable Jetstream cursor tracking (useful in development to avoid
# backfilling events from previous sessions)
# Set to "true", "1", or "yes" to disable
# JETSTREAM_DISABLE_CURSOR=false

# =============================================================================
# Tap Configuration (alternative to Jetstream — crypto-verified events)
# =============================================================================

# Enable Tap consumer instead of Jetstream
# TAP_ENABLED=false

# Tap WebSocket URL (default wss://localhost:2480)
# TAP_URL=wss://localhost:2480

# Password for Tap admin API (required when TAP_ENABLED=true)
# Generate with: openssl rand -base64 32
# TAP_ADMIN_PASSWORD=

# Fire-and-forget mode (skip ack-based delivery)
# TAP_DISABLE_ACKS=false

# Comma-separated collection NSIDs to accept from Tap
# TAP_COLLECTION_FILTERS=

# Per-event retry limit (default 3)
# TAP_MAX_RETRIES=3

# =============================================================================
# Notifications (Bluesky-style per-user notification feed)
# =============================================================================

# Enable the notifications subsystem. When false, the notification GraphQL
# fields are not registered and no hook is attached to the RecordProcessor.
# Default false.
# NOTIFICATIONS_ENABLED=false

# =============================================================================
# Backfill Configuration
# =============================================================================

# Run backfill on server start
# BACKFILL_ON_START=false

# Collections to backfill (comma-separated, defaults to JETSTREAM_COLLECTIONS)
# BACKFILL_COLLECTIONS=

# Relay URL for discovering repos (com.atproto.sync.listReposByCollection)
# BACKFILL_RELAY_URL=https://relay1.us-west.bsky.network

# PLC directory URL for resolving DIDs
# BACKFILL_PLC_URL=https://plc.directory

# Concurrent requests per PDS during backfill
# BACKFILL_PDS_CONCURRENCY=4

# Global maximum concurrent HTTP requests (prevents overwhelming network)
# Higher = faster but more resource intensive
# BACKFILL_MAX_HTTP=50

# Maximum concurrent PDS workers (sliding window pattern)
# Each PDS is processed independently with up to MAX_PER_PDS concurrent requests
# BACKFILL_MAX_PDS_WORKERS=10

# Maximum concurrent requests per PDS during backfill
# Prevents overwhelming individual PDS servers
# BACKFILL_MAX_PER_PDS=6

# Maximum concurrent DID resolutions during discovery phase
# BACKFILL_MAX_REPOS=50

# Timeout per repo in milliseconds
# BACKFILL_REPO_TIMEOUT=60000

# =============================================================================
# PLC Directory
# =============================================================================

# PLC directory URL for DID resolution (default: https://plc.directory)
# PLC_DIRECTORY_URL=

# =============================================================================
# Labelers
# =============================================================================

# Comma-separated list of labeler DIDs to subscribe to. When set, the server
# connects to each labeler's com.atproto.label.subscribeLabels endpoint and
# ingests labels into the local label table. Existing labels are fetched
# once via queryLabels on first start, then the live subscription takes
# over. Cursors are persisted per-labeler in the config table so restarts
# resume cleanly. The first DID in this list is also the default used by
# label-filtered GraphQL queries; clients can override with `labelerDid`.
#
# Example: subscribe to the Hypercerts quality labeler
# LABELER_DIDS=did:plc:5rw6of6lry7ihmyhm323ycwn
# LABELER_DIDS=

# Dry-run mode: resolve each labeler's host via PLC and log the result,
# then exit without ingesting any labels. Useful for validating a new
# labeler DID in staging without committing cursor state.
# LABELER_DRY_RUN=false

# Cursor flush cadence in seconds (default 5). Raise to reduce write
# pressure on the config table; lower to reduce the crash-loss window.
# LABELER_CURSOR_FLUSH_INTERVAL=5

# =============================================================================
# External Services (Defaults configured via Admin UI)
# =============================================================================
# These settings can also be configured through the Settings page (/settings)
#
# Defaults:
#   - Relay URL: https://relay1.us-west.bsky.network
#   - PLC Directory URL: https://plc.directory
#   - Jetstream URL: wss://jetstream2.us-west.bsky.network/subscribe
#   - OAuth Supported Scopes: atproto transition:generic
